# =====================================================================
# SUDOKU GA + scalable fitness pool — all parameters in one place.
# =====================================================================

# ---- Problem ----
PUZZLE=classic            # runs full length -> timing differences accumulate
MAX_GENERATIONS=120       # enough to show the timing curve without waiting too long

# ---- Fitness evaluation cost ----
# Counting Sudoku conflicts is microsecond-cheap. To STUDY POOL SCALING we
# add a small controllable cost per grid (a stand-in for an expensive real
# fitness like the parking problem). Set 0 to disable.
EVAL_DELAY_MS=15          # EXPENSIVE fitness -> evaluation becomes the bottleneck

# ---- GA hyperparameters ----
POP_SIZE=400             # more grids to score -> more work to parallelise
MUTATION_RATE=0.25        # per-row swap probability
CROSSOVER_RATE=0.85
TOURNAMENT_K=5
ELITE_COUNT=6
SEED=7

# ---- Escape mechanisms (GA-side; distinct from the scaler) ----
HYPERMUTATION_FACTOR=10
STAGNATION_FOR_HYPERMUT=25
STAGNATION_FOR_RESTART=80

# ---- Fitness client (GA -> pool) ----
EVAL_CONCURRENCY=48

#EVAL_CONCURRENCY=6

#EVAL_CONCURRENCY=30


# ---- Rate tracking + scaling ----
RATE_WINDOW=5
STAGNATION_THRESHOLD=0.2  # rate below this = "not increasing"
SLOW_GEN_MS=300           # a generation slower than this = "slow"
HEALTHY_RATE=1.0          # rate above this = improving well -> can scale down
MIN_WORKERS=1
MAX_WORKERS=12     	# changed from 6 to 12 to get different result 
REQUEST_TIMEOUT=300        # 1-worker runs serialize ~50s; give ample headroom
